# Spotify to MP3 Downloader - Configuration
# Copy this file to .env and modify as needed

# Music directory (where playlists are stored)
MUSIC_DIR=/mnt/ssd/Music

# Spotify API credentials
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Download quality (192K, 256K, 320K, best)
DOWNLOAD_QUALITY=192K

# Enable audio fingerprinting for content-based deduplication (true/false)
ENABLE_AUDIO_FINGERPRINT=false

# Base directories to check for duplicates (comma-separated)
DUPLICATE_CHECK_DIRS=/mnt/ssd/Music
